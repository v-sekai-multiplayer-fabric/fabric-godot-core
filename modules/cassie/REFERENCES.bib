% =============================================================================
% System architecture
% =============================================================================

@misc{maccarthaigh_constant_work,
  author       = {Mac C{\'a}rthaigh, Colm},
  title        = {Reliability, constant work, and a good cup of coffee},
  howpublished = {\url{https://aws.amazon.com/builders-library/reliability-and-constant-work/}},
  publisher    = {Amazon Web Services Builders' Library},
  note         = {Constant-work systems do the same amount of work
                  regardless of input state — no early exits, no
                  branches on "is it converged?", no scaling of work
                  with load. Predictable wall time replaces
                  best-case-fast / worst-case-slow variance. The
                  CgUbershader's fixed iter count follows this pattern:
                  every solve dispatches the same N kernels with the
                  same dispatch shapes regardless of how fast the
                  residual would have converged. Real-time graphics
                  (Quest 3 90Hz) needs predictability, not minimum
                  average cost.}
}

