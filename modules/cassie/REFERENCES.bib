% =============================================================================
% Vertex normal weighting + deformation-gradient normal transfer (ENG-65)
% =============================================================================

@article{max1999weights,
  author  = {Max, Nelson},
  title   = {Weights for Computing Vertex Normals from Facet Normals},
  journal = {Journal of Graphics Tools},
  volume  = {4},
  number  = {2},
  pages   = {1--6},
  year    = {1999},
  doi     = {10.1080/10867651.1999.10487501},
  note    = {Proves angle-weighted averaging is the optimal per-vertex
             normal weighting --- independent of triangulation, robust
             to slivers, converges to the true surface normal as the
             mesh refines. CASSIE uses this as the fallback when the
             source mesh's \texttt{ARRAY\_NORMAL} is absent (Linear
             ENG-65 phase 1).}
}

@article{sumner2004deformation,
  author  = {Sumner, Robert W. and Popovi{\'c}, Jovan},
  title   = {Deformation Transfer for Triangle Meshes},
  journal = {ACM Trans. Graph.},
  volume  = {23},
  number  = {3},
  pages   = {399--405},
  year    = {2004},
  doi     = {10.1145/1015706.1015736},
  note    = {Per-face deformation gradient J = $\partial x_{def} /
             \partial x_{rest}$; deformed face normal is
             $J^{-T} \cdot n_{rest}$ normalized. CASSIE
             transfers captured rest normals through J at deform time
             to preserve split-normal / smoothing-group intent that
             pure recomputation would erase (ENG-65 phase 1, step 7).
             Per-vertex normal = $J^{-T}$ applied to the captured rest
             vertex normal, averaged angle-weighted (Max 1999) over
             incident faces.}
}

% =============================================================================
% Robust skin weight transfer (reserved for cross-topology bind)
% =============================================================================

@inproceedings{abdrashitov2023robust,
  author    = {Abdrashitov, Rinat and Raichstat, Kim and Monsen, Jared
                and Hill, David},
  title     = {Robust Skin Weights Transfer via Weight Inpainting},
  booktitle = {SIGGRAPH Asia 2023 Technical Communications},
  year      = {2023},
  doi       = {10.1145/3610543.3626180},
  note      = {Biharmonic-energy inpainting ($Q = -L + L M^{-1} L$)
             with constrained-least-squares fixed values at matched
             vertices. Solves the cross-topology data-transfer
             problem (skin weights from a body mesh to a garment
             with totally different topology). NOT used in the
             CASSIE per-frame deform: we have full 1:1 vertex
             correspondence between rest and deformed states, so
             inpainting solves a problem we do not have. Reserved
             for a future bind-time use case where the CASSIE
             working mesh is a different topology from a high-LOD
             source sculpt and rest normals / skin weights need to
             cross over. Reference Python implementation at
             \texttt{E:/godot-robust-skin-weights-transfer}.}
}

