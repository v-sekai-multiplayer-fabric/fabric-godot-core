{
  "@context": {"khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/", "domain": "khr:planning/domain/"},
  "@type": "domain:Problem",
  "name": "blocks_world_goal",
  "source": "blocks_world",
  "description": "IPyHOP blocks_world goal-based: achieve c on b on a on table.",
  "variables": [
    {"name": "pos",     "init": {"a": "b", "b": "table", "c": "table"}},
    {"name": "clear",   "init": {"c": true, "b": false, "a": true}},
    {"name": "holding", "init": {"hand": false}}
  ],
  "goals": [
    {"pointer": "/pos/a", "eq": "table"},
    {"pointer": "/pos/b", "eq": "a"},
    {"pointer": "/pos/c", "eq": "b"}
  ]
}
