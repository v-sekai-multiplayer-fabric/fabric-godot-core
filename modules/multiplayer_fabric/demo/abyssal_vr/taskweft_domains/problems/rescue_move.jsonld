{
  "@context": {"khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/", "domain": "khr:planning/domain/"},
  "@type": "domain:Problem",
  "name": "rescue_move",
  "source": "rescue",
  "description": "IPyHOP rescue problem 1: move wheeled robot r1 to person location.",
  "variables": [
    {"name": "loc",         "init": {"r1": 0, "w1": 1, "p1": 2, "a1": 3}},
    {"name": "robot_type",  "init": {"r1": 0, "w1": 0, "a1": 1}},
    {"name": "has_medicine","init": {"a1": 0, "w1": 0, "r1": 0}},
    {"name": "status",      "init": {"r1": 0, "w1": 0, "a1": 3, "p1": 3}},
    {"name": "altitude",    "init": {"a1": 0}}
  ],
  "tasks": [["move_task", "r1", 2]]
}
