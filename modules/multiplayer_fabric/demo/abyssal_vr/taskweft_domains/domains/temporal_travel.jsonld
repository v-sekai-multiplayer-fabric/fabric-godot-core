{
  "@context": {"khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/", "domain": "khr:planning/domain/"},
  "@type": "domain:Definition",
  "name": "temporal_travel",
  "enums": {"location": {"home_a": 0, "home_b": 1, "park": 2, "station": 3, "downtown": 4}},
  "variables": [
    {"name": "loc",  "init": {"alice": 0, "bob": 1, "taxi1": 2, "taxi2": 3}},
    {"name": "cash", "init": {"alice": 20.0, "bob": 15.0}},
    {"name": "owe",  "init": {"alice": 0.0, "bob": 0.0}}
  ],
  "actions": {
    "a_walk":      {"params": ["person", "to_loc"], "body": [{"set": "/loc/{person}", "value": "{to_loc}"}]},
    "a_call_taxi": {"params": ["person"], "bind": [{"name": "here", "pointer": "/loc/{person}"}], "body": [{"set": "/loc/taxi1", "value": "{here}"}, {"set": "/loc/{person}", "value": -1}]},
    "a_ride_taxi": {"params": ["person", "to_loc"], "body": [{"check": "/loc/{person}", "eq": -1}, {"set": "/loc/taxi1", "value": "{to_loc}"}, {"set": "/owe/{person}", "value": {"op": "add", "a": 1.5, "b": {"op": "mul", "a": 0.5, "b": 8}}}]},
    "a_pay_driver": {"params": ["person", "to_loc"], "bind": [{"name": "owed", "pointer": "/owe/{person}"}], "body": [{"check": "/cash/{person}", "ge": "{owed}"}, {"set": "/cash/{person}", "value": {"op": "sub", "a": {"op": "get", "pointer": "/cash/{person}"}, "b": "{owed}"}}, {"set": "/owe/{person}", "value": 0.0}, {"set": "/loc/{person}", "value": "{to_loc}"}]}
  },
  "methods": {
    "travel": {"params": ["person", "dest"], "alternatives": [
      {"name": "already_there", "check": [{"pointer": "/loc/{person}", "eq": "{dest}"}], "subtasks": []},
      {"name": "by_foot", "subtasks": [["a_walk", "{person}", "{dest}"]]},
      {"name": "by_taxi", "subtasks": [["a_call_taxi", "{person}"], ["a_ride_taxi", "{person}", "{dest}"], ["a_pay_driver", "{person}", "{dest}"]]}
    ]}
  },
  "tasks": [["travel", "alice", 2]]
}
