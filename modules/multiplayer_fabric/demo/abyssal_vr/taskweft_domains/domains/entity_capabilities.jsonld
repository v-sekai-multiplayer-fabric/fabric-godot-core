{
  "@context": {"khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/", "domain": "khr:planning/domain/"},
  "@type": "domain:Definition",
  "name": "entity_capabilities",
  "enums": {"location": {"base": 0, "mountain": 1, "harbor": 2, "offshore": 3, "city": 4, "shore": 5, "island": 6}},
  "variables": [
    {"name": "loc", "init": {"drone_1": 0, "drone_2": 0, "boat_1": 2, "boat_2": 2, "human_1": 0, "human_2": 0, "amphibious_1": 5}}
  ],
  "capabilities": {
    "entities": {"drone_1": ["fly"], "drone_2": ["fly"], "boat_1": ["swim"], "boat_2": ["swim"], "human_1": ["walk"], "human_2": ["walk"], "amphibious_1": ["swim", "walk"]},
    "actions": {"a_fly": ["fly"], "a_swim": ["swim"], "a_walk": ["walk"]}
  },
  "actions": {
    "a_fly":  {"params": ["agent", "to_loc"], "body": [{"set": "/loc/{agent}", "value": "{to_loc}"}]},
    "a_swim": {"params": ["agent", "to_loc"], "body": [{"set": "/loc/{agent}", "value": "{to_loc}"}]},
    "a_walk": {"params": ["agent", "to_loc"], "body": [{"set": "/loc/{agent}", "value": "{to_loc}"}]}
  },
  "methods": {
    "m_move": {"params": ["agent", "to_loc"], "alternatives": [
      {"name": "fly",  "subtasks": [["a_fly",  "{agent}", "{to_loc}"]]},
      {"name": "swim", "subtasks": [["a_swim", "{agent}", "{to_loc}"]]},
      {"name": "walk", "subtasks": [["a_walk", "{agent}", "{to_loc}"]]}
    ]}
  },
  "tasks": [["m_move", "drone_1", 1]]
}
