{
  "@context": {"khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/", "domain": "khr:planning/domain/"},
  "@type": "domain:Definition",
  "name": "robosub",
  "variables": [
    {"name": "loc",             "init": {"robot": "l0"}},
    {"name": "found",           "init": {"l0": 1, "l1": 0, "l2": 0, "l3": 0, "l4": 0, "l5": 0, "g": 0, "v1": 0, "v2": 0}},
    {"name": "crossed_gate",    "init": {"g": 0}},
    {"name": "vampire_touched", "init": {"v1": 0, "v2": 0}},
    {"name": "surfaced",        "init": {"robot": 0}}
  ],
  "actions": {
    "a_search_for":    {"params": ["target"],  "body": [{"set": "/found/{target}", "value": 1}]},
    "a_move":          {"params": ["loc_id"],  "body": [{"check": "/found/{loc_id}", "eq": 1}, {"set": "/loc/robot", "value": "{loc_id}"}]},
    "a_cross_gate_40": {"params": ["gate"],    "body": [{"check": "/found/{gate}", "eq": 1}, {"set": "/crossed_gate/{gate}", "value": 1}]},
    "a_cross_gate_60": {"params": ["gate"],    "body": [{"check": "/found/{gate}", "eq": 1}, {"set": "/crossed_gate/{gate}", "value": 1}]},
    "a_touch_front_v": {"params": ["vampire"], "body": [{"check": "/found/{vampire}", "eq": 1}, {"set": "/vampire_touched/{vampire}", "value": 1}]},
    "a_touch_back_v":  {"params": ["vampire"], "body": [{"check": "/found/{vampire}", "eq": 1}, {"set": "/vampire_touched/{vampire}", "value": 2}]},
    "a_surface":       {"params": [],          "body": [{"set": "/surfaced/robot", "value": 1}]}
  },
  "methods": {
    "move_task": {"params": ["loc_id"], "alternatives": [
      {"name": "already_there", "check": [{"pointer": "/loc/robot", "eq": "{loc_id}"}], "subtasks": []},
      {"name": "search_and_move", "subtasks": [["a_search_for", "{loc_id}"], ["a_move", "{loc_id}"]]}
    ]},
    "cross_gate_task": {"params": ["gate"], "alternatives": [
      {"name": "already_crossed", "check": [{"pointer": "/crossed_gate/{gate}", "eq": 1}], "subtasks": []},
      {"name": "search_cross_40", "subtasks": [["a_search_for", "{gate}"], ["a_cross_gate_40", "{gate}"]]},
      {"name": "search_cross_60", "subtasks": [["a_search_for", "{gate}"], ["a_cross_gate_60", "{gate}"]]}
    ]},
    "slay_vampire_task": {"params": ["vampire"], "alternatives": [
      {"name": "already_slayed", "check": [{"pointer": "/vampire_touched/{vampire}", "igt": 0}], "subtasks": []},
      {"name": "search_touch_front", "subtasks": [["a_search_for", "{vampire}"], ["a_touch_front_v", "{vampire}"]]},
      {"name": "search_touch_back", "subtasks": [["a_search_for", "{vampire}"], ["a_touch_back_v", "{vampire}"]]}
    ]},
    "main_task": {"params": [], "alternatives": [
      {"name": "full_mission", "subtasks": [
        ["move_task", "l1"], ["cross_gate_task", "g"], ["move_task", "l2"],
        ["move_task", "l3"], ["slay_vampire_task", "v1"],
        ["move_task", "l4"], ["slay_vampire_task", "v2"],
        ["move_task", "l5"], ["a_surface"]
      ]}
    ]}
  },
  "tasks": [["main_task"]]
}
