{
  "@context": {"khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/", "domain": "khr:planning/domain/"},
  "@type": "domain:Definition",
  "name": "healthcare",
  "enums": {"room_status": {"available": 0, "prepared": 1, "in_use": 2, "recovered": 3, "cleaned": 4}},
  "variables": [
    {"name": "room_status",      "init": {"OR1": 0, "OR2": 0, "OR3": 4}},
    {"name": "room_equipment",   "init": {"OR1": 0, "OR2": 1, "OR3": 0}},
    {"name": "surgery_complete", "init": {"patient1": 0, "patient2": 0, "patient3": 0}}
  ],
  "actions": {
    "a_prepare_room":    {"params": ["room", "stype"], "body": [{"set": "/room_status/{room}", "value": 1}]},
    "a_perform_surgery": {"params": ["patient", "room", "stype"], "body": [{"check": "/room_status/{room}", "eq": 1}, {"set": "/room_status/{room}", "value": 2}, {"set": "/surgery_complete/{patient}", "value": 1}]},
    "a_recover_patient": {"params": ["patient", "room"], "body": [{"check": "/surgery_complete/{patient}", "eq": 1}, {"set": "/room_status/{room}", "value": 0}]},
    "a_clean_room":      {"params": ["room"], "body": [{"check": "/room_status/{room}", "eq": 0}, {"set": "/room_status/{room}", "value": 4}]}
  },
  "methods": {
    "schedule_surgery": {"params": ["patient", "room", "stype"], "alternatives": [
      {"name": "full_workflow", "subtasks": [["a_prepare_room", "{room}", "{stype}"], ["a_perform_surgery", "{patient}", "{room}", "{stype}"], ["a_recover_patient", "{patient}", "{room}"], ["a_clean_room", "{room}"]]},
      {"name": "simple_workflow", "subtasks": [["a_prepare_room", "{room}", "{stype}"], ["a_perform_surgery", "{patient}", "{room}", "{stype}"], ["a_recover_patient", "{patient}", "{room}"]]}
    ]}
  },
  "tasks": [["schedule_surgery", "patient1", "OR1", "cardiac"]]
}
