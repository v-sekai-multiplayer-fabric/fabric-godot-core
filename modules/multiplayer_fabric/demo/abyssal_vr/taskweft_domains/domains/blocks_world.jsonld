{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Definition",
  "name": "blocks_world",
  "variables": [
    {"name": "pos",     "init": {"a": "b", "b": "table", "c": "table"}},
    {"name": "clear",   "init": {"a": true, "b": false, "c": true}},
    {"name": "holding", "init": {"hand": false}}
  ],
  "actions": {
    "a_pickup": {
      "params": ["block"],
      "body": [
        {"check": "/pos/{block}",     "eq": "table"},
        {"check": "/clear/{block}",   "eq": true},
        {"check": "/holding/hand",    "eq": false},
        {"set":   "/pos/{block}",     "value": "hand"},
        {"set":   "/clear/{block}",   "value": false},
        {"set":   "/holding/hand",    "value": "{block}"}
      ]
    },
    "a_unstack": {
      "params": ["block"],
      "bind": [{"name": "under", "pointer": "/pos/{block}"}],
      "body": [
        {"check": "/clear/{block}",   "eq": true},
        {"check": "/holding/hand",    "eq": false},
        {"set":   "/pos/{block}",     "value": "hand"},
        {"set":   "/clear/{block}",   "value": false},
        {"set":   "/holding/hand",    "value": "{block}"},
        {"set":   "/clear/{under}",   "value": true}
      ]
    },
    "a_putdown": {
      "params": ["block"],
      "body": [
        {"check": "/pos/{block}",     "eq": "hand"},
        {"set":   "/pos/{block}",     "value": "table"},
        {"set":   "/clear/{block}",   "value": true},
        {"set":   "/holding/hand",    "value": false}
      ]
    },
    "a_stack": {
      "params": ["block", "target"],
      "body": [
        {"check": "/pos/{block}",     "eq": "hand"},
        {"check": "/clear/{target}",  "eq": true},
        {"set":   "/pos/{block}",     "value": "{target}"},
        {"set":   "/clear/{block}",   "value": true},
        {"set":   "/holding/hand",    "value": false},
        {"set":   "/clear/{target}",  "value": false}
      ]
    }
  },
  "methods": {
    "move_one": {
      "params": ["block", "dest"],
      "alternatives": [
        {"name": "get_and_put", "subtasks": [["get", "{block}"], ["put", "{block}", "{dest}"]]}
      ]
    },
    "get": {
      "params": ["block"],
      "alternatives": [
        {"name": "pickup_from_table", "check": [{"pointer": "/pos/{block}", "eq": "table"}], "subtasks": [["a_pickup", "{block}"]]},
        {"name": "unstack", "subtasks": [["a_unstack", "{block}"]]}
      ]
    },
    "put": {
      "params": ["block", "dest"],
      "alternatives": [
        {"name": "stack_on_block", "check": [{"pointer": "/holding/hand", "eq": "{block}"}, {"pointer": "/clear/{dest}", "eq": true}], "subtasks": [["a_stack", "{block}", "{dest}"]]},
        {"name": "putdown_on_table", "check": [{"pointer": "/holding/hand", "eq": "{block}"}], "subtasks": [["a_putdown", "{block}"]]}
      ]
    }
  },
  "goals": {
    "pos": {
      "params": ["block", "dest"],
      "alternatives": [
        {"name": "move_via_hand", "subtasks": [["move_one", "{block}", "{dest}"]]}
      ]
    }
  },
  "multigoals": {
    "rearrange": {"goal_tag": null, "alternatives": [{"name": "move_blocks"}]}
  },
  "tasks": [["move_one", "a", "table"], ["move_one", "c", "b"], ["move_one", "b", "a"]]
}
