#!/usr/bin/env python
from misc.utility.scons_hints import *

Import("env")
Import("env_modules")

env_native_media = env_modules.Clone()

# NV12 -> RGBA compute shader (used on Vulkan / D3D12 / Metal via
# RenderingDevice). The Compatibility (OpenGL) renderer uses
# ycbcr_sampler_compat.gdshader (loaded at runtime, no SCons step needed).
env_native_media.GLSL_HEADER("ycbcr_sampler.glsl")
env_native_media.Depends(Glob("*.glsl.gen.h"), ["#glsl_builders.py"])

# Module-level sources (abstraction layer + Godot Resource wrappers).
env_native_media.add_source_files(env.modules_sources, "*.cpp")

# Per-platform backend selection.
platform = env["platform"]

if platform == "windows":
    env_native_media.add_source_files(env.modules_sources, "backends/mediafoundation/*.cpp")
    # Core MF, plus D3D11 + DXGI for the zero-copy bridge (task #12).
    mf_libs = ["mf", "mfplat", "mfreadwrite", "mfuuid", "ole32", "shlwapi", "propsys", "d3d11", "dxgi", "dxguid"]
    if env.msvc:
        # Module SCsubs run after SConstruct decorates LIBSUFFIX with the
        # platform/target/arch tag, so a bare name in env["LIBS"] would resolve
        # to e.g. "mfuuid.windows.editor.x86_64.lib" and fail to link. These are
        # system import libraries — link them by their real ".lib" name through
        # LINKFLAGS instead (works for both MSVC link and clang-cl lld-link).
        env.Append(LINKFLAGS=[lib + ".lib" for lib in mf_libs])
    else:
        env.Append(LIBS=mf_libs)
elif platform == "linuxbsd":
    # GStreamer goes through thirdparty/generate_stubs/generate_stubs.py:
    # dlopen at runtime, no -lgstreamer-1.0 at link time, no gstreamer-1.0-dev
    # headers needed at build time. Vendored declarations live in
    # backends/gstreamer/gst_decls.h. LGPL-clean dynamic loading.
    import sys

    gst_sigs = "backends/gstreamer/gstreamer.sigs"
    gst_stub_h = "backends/gstreamer/gstreamer_stubs.h"
    gst_stub_cc = "backends/gstreamer/gstreamer_stubs.cc"
    gst_stub = env_native_media.Command(
        [gst_stub_h, gst_stub_cc],
        [gst_sigs, "#thirdparty/generate_stubs/generate_stubs.py"],
        [
            [
                sys.executable,
                "#thirdparty/generate_stubs/generate_stubs.py",
                "-o",
                env.Dir("backends/gstreamer").srcnode().path,
                "-i",
                env.Dir("backends/gstreamer").srcnode().path,
                "-t",
                "posix_stubs",
                "-s",
                "gstreamer_stubs",
                "-p",
                "modules/native_media/backends/gstreamer",
                "-l",
                "(::std::cerr)",
                "-n",
                "iostream",
                "--macro-include",
                "modules/native_media/backends/gstreamer/stubgen_compat.h",
                "$SOURCE",
            ]
        ],
    )
    # gstreamer_backend.cpp #includes the generated gstreamer_stubs.h, and the
    # generated gstreamer_stubs.cc carries the dlsym dispatch table that must be
    # compiled and linked. Glob can't see a file that does not exist at
    # SConscript-parse time, so add the generated .cc explicitly with
    # allow_gen=True, and make every GStreamer object depend on the generator so
    # a parallel build cannot compile the backend before the stubs are emitted.
    gst_obj = []
    env_native_media.add_source_files(gst_obj, "backends/gstreamer/*.cpp")
    env_native_media.add_source_files(gst_obj, [gst_stub_cc], allow_gen=True)
    env.modules_sources += gst_obj
    env_native_media.Depends(gst_obj, gst_stub)
    env_native_media.Append(CPPDEFINES=["GSTREAMER_ENABLED"])
    env.Append(LIBS=["dl"])
else:
    # Other platforms (macOS, iOS, Android, Web) are not yet supported.
    # NativeMediaBackend::create() returns nullptr until a backend is added.
    pass
