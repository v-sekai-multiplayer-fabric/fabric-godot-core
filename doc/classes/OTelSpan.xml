<?xml version="1.0" encoding="UTF-8" ?>
<class name="OTelSpan" inherits="Resource" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../class.xsd">
	<brief_description>
		A single trace span representing one unit of work.
	</brief_description>
	<description>
		Stores span metadata (IDs, timing, attributes, events, links, status) and serializes to OTLP format.
	</description>
	<tutorials>
	</tutorials>
	<methods>
		<method name="add_attribute">
			<return type="void" />
			<param index="0" name="key" type="String" />
			<param index="1" name="value" type="Variant" />
			<description>
				Adds or replaces attribute [param key] with [param value].
			</description>
		</method>
		<method name="add_event">
			<return type="void" />
			<param index="0" name="name" type="String" />
			<param index="1" name="attributes" type="Dictionary" default="{}" />
			<param index="2" name="timestamp" type="int" default="0" />
			<description>
				Records a named event at [param timestamp] (0 = now) with optional [param attributes].
			</description>
		</method>
		<method name="add_link">
			<return type="void" />
			<param index="0" name="trace_id" type="String" />
			<param index="1" name="span_id" type="String" />
			<param index="2" name="attributes" type="Dictionary" default="{}" />
			<description>
				Adds a causal link to the span identified by [param trace_id] and [param span_id].
			</description>
		</method>
		<method name="generate_span_id" qualifiers="static">
			<return type="String" />
			<description>
				Returns a new random 16-char hex span ID.
			</description>
		</method>
		<method name="generate_trace_id" qualifiers="static">
			<return type="String" />
			<description>
				Returns a new random 32-char hex trace ID.
			</description>
		</method>
		<method name="is_ended" qualifiers="const">
			<return type="bool" />
			<description>
				Returns [code]true[/code] if [method mark_ended] has been called.
			</description>
		</method>
		<method name="is_valid_span_id" qualifiers="static">
			<return type="bool" />
			<param index="0" name="id" type="String" />
			<description>
				Returns [code]true[/code] if [param id] is a valid 16-char hex span ID.
			</description>
		</method>
		<method name="is_valid_trace_id" qualifiers="static">
			<return type="bool" />
			<param index="0" name="id" type="String" />
			<description>
				Returns [code]true[/code] if [param id] is a valid 32-char hex trace ID.
			</description>
		</method>
		<method name="mark_ended">
			<return type="void" />
			<description>
				Records [member end_time_unix_nano] as the current nanosecond timestamp.
			</description>
		</method>
		<method name="to_otlp_dict" qualifiers="const">
			<return type="Dictionary" />
			<description>
				Returns the span as an OTLP-format Dictionary.
			</description>
		</method>
	</methods>
	<members>
		<member name="attributes" type="Dictionary" setter="set_attributes" getter="get_attributes" default="{}">
		</member>
		<member name="end_time_unix_nano" type="int" setter="set_end_time_unix_nano" getter="get_end_time_unix_nano" default="0">
		</member>
		<member name="events" type="Dictionary[]" setter="set_events" getter="get_events" default="[]">
		</member>
		<member name="kind" type="int" setter="set_kind" getter="get_kind" enum="OTelSpan.SpanKind" default="1">
		</member>
		<member name="links" type="Dictionary[]" setter="set_links" getter="get_links" default="[]">
		</member>
		<member name="name" type="String" setter="set_name" getter="get_name" default="&quot;&quot;">
		</member>
		<member name="parent_span_id" type="String" setter="set_parent_span_id" getter="get_parent_span_id" default="&quot;&quot;">
		</member>
		<member name="span_id" type="String" setter="set_span_id" getter="get_span_id" default="&quot;&quot;">
		</member>
		<member name="start_time_unix_nano" type="int" setter="set_start_time_unix_nano" getter="get_start_time_unix_nano" default="0">
		</member>
		<member name="status_code" type="int" setter="set_status_code" getter="get_status_code" enum="OTelSpan.StatusCode" default="0">
		</member>
		<member name="status_message" type="String" setter="set_status_message" getter="get_status_message" default="&quot;&quot;">
		</member>
		<member name="trace_id" type="String" setter="set_trace_id" getter="get_trace_id" default="&quot;&quot;">
		</member>
	</members>
	<constants>
		<constant name="SPAN_KIND_UNSPECIFIED" value="0" enum="SpanKind">
			Span kind not specified.
		</constant>
		<constant name="SPAN_KIND_INTERNAL" value="1" enum="SpanKind">
			Internal operation within a single process.
		</constant>
		<constant name="SPAN_KIND_SERVER" value="2" enum="SpanKind">
			Server handling an inbound request.
		</constant>
		<constant name="SPAN_KIND_CLIENT" value="3" enum="SpanKind">
			Client sending an outbound request.
		</constant>
		<constant name="SPAN_KIND_PRODUCER" value="4" enum="SpanKind">
			Producer sending a message.
		</constant>
		<constant name="SPAN_KIND_CONSUMER" value="5" enum="SpanKind">
			Consumer receiving a message.
		</constant>
		<constant name="STATUS_CODE_UNSET" value="0" enum="StatusCode">
			Status has not been set.
		</constant>
		<constant name="STATUS_CODE_OK" value="1" enum="StatusCode">
			Operation completed successfully.
		</constant>
		<constant name="STATUS_CODE_ERROR" value="2" enum="StatusCode">
			Operation encountered an error.
		</constant>
	</constants>
</class>
